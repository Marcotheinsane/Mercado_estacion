{
    "buildCommand": "echo 'No build needed'",
    "installCommand": "npm install",
    "regions": [
        "sfo1"
    ],
    "functions": {
        "api/**/*.js": {
            "runtime": "nodejs20.x"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/$1"
        }
    ]
}